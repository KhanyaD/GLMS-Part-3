<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GLMS</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="navbar">
        <div class="container nav-inner">
            <a class="brand" asp-controller="Home" asp-action="Index">GLMS</a>
            <nav>
                <a asp-controller="Clients" asp-action="Index">Clients</a>
                <a asp-controller="Contracts" asp-action="Index">Contracts</a>
                <a asp-controller="ServiceRequests" asp-action="Index">Service Requests</a>
            </nav>
        </div>
    </header>

    <main class="container">
        @if (TempData["Success"] is string message)
        {
            <div class="alert-success">@message</div>
        }
        @RenderBody()
    </main>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
